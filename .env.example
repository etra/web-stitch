# Flask configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database configuration
DATABASE_URL=postgresql://user:pass@localhost/webstitch

# OAuth configuration (optional — leave empty to disable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Mail configuration (required for magic link authentication)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@ourstitch.com
